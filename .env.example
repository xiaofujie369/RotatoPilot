APP_ENV=production
APP_PORT=8080
HOST_PORT=8080
PUBLIC_URL=http://127.0.0.1:8080

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_use_at_least_12_characters
JWT_SECRET=change_me_use_a_random_32_byte_secret
APP_ENCRYPTION_KEY=change_me_use_a_random_32_byte_secret

DB_DRIVER=sqlite
DB_PATH=/app/data/app.db

AUTO_ROTATE_GLOBAL_ENABLED=false
CHECK_INTERVAL_SECONDS=300
FAILURE_THRESHOLD=3
SUCCESS_RECOVERY_THRESHOLD=2
ROTATION_COOLDOWN_MINUTES=30
CHANGE_IP_WAIT_SECONDS=180
CHANGE_IP_POLL_TIMEOUT_SECONDS=600
MAX_ROTATIONS_PER_DAY=10
REQUIRE_CONFIRMATION_CHECK=true

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LOG_LEVEL=info
